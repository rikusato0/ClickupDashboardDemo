# ClickUp — Settings → Integrations → API
CLICKUP_API_TOKEN=pk_your_token_here
# Default: White Lotus Bookkeeping workspace
CLICKUP_TEAM_ID=24568950

# MongoDB (required for full dashboard)
MONGODB_URI=mongodb://127.0.0.1:27017/wl-metrics

# OpenAI (thread classification, sentiment, predicted needs)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gmail — Google Cloud OAuth2 (Desktop or Web app). Grant Gmail readonly + modify if needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# From OAuth flow — long-lived refresh token for the mailbox you sync.
GMAIL_REFRESH_TOKEN=
# Must match the Google account that owns the refresh token.
GMAIL_USER_EMAIL=
# Staff domain for inbound/outbound detection (your firm)
STAFF_EMAIL_DOMAIN=whitelotusbk.com
# Optional: map ClickUp client ids to inbound email domains, JSON object:
# { "f-123456": ["clientdomain.com"], "s-789": ["other.org"] }
CLIENT_EMAIL_DOMAINS_JSON=

# Sync windows
GMAIL_SYNC_DAYS=120
GMAIL_MAX_MESSAGES=800

# Optional: Zoom app webhook signing secret (see Zoom Marketplace app)
ZOOM_WEBHOOK_SECRET=

# PORT=3001
