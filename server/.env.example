# --- Public URLs (production example) ---
# Browser SPA + API share host; nginx proxies /api → Express.
PUBLIC_SITE_ORIGIN=https://metrics.whitelotusbk.ai
PUBLIC_API_ORIGIN=https://metrics.whitelotusbk.ai/api

# ClickUp — Settings → Integrations → API
CLICKUP_API_TOKEN=pk_your_token_here
# Default: White Lotus Bookkeeping workspace
CLICKUP_TEAM_ID=24568950
# Label for the dashboard banner (primary workspace)
CLICKUP_WORKSPACE_DISPLAY_NAME=White Lotus Bookkeeping

# MongoDB (required for full dashboard). Local: run `docker compose up -d` in repo root.
MONGODB_URI=mongodb://127.0.0.1:27017/wl-metrics

# OpenAI (thread classification, sentiment, predicted needs)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gmail — Google Cloud OAuth2 (Desktop or Web app). Grant Gmail readonly + modify if needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# From OAuth flow — long-lived refresh token for the mailbox you sync.
GMAIL_REFRESH_TOKEN=
# Must match the Google account that owns the refresh token.
GMAIL_USER_EMAIL=
# Staff domain for inbound/outbound detection (your firm)
STAFF_EMAIL_DOMAIN=whitelotusbk.com
# Optional: map ClickUp client ids to inbound email domains, JSON object:
# { "f-123456": ["clientdomain.com"], "s-789": ["other.org"] }
CLIENT_EMAIL_DOMAINS_JSON=
# Optional: map client ids to specific contact addresses (multi-person orgs, personal Gmail, etc.)
# { "f-123456": ["ceo@gmail.com","ap@partner.org"] } — merged with Mongo Client.contactEmails on sync
CLIENT_CONTACT_EMAILS_JSON=

# Calendar day for once-per-day external sync (GET /api/dashboard + background interval)
SYNC_TIMEZONE=America/New_York
# How often to check if a new calendar day started (ms). Default 1 hour.
SYNC_INTERVAL_MS=3600000

# Sync windows
GMAIL_SYNC_DAYS=120
GMAIL_MAX_MESSAGES=800

# Optional: Zoom app webhook signing secret (see Zoom Marketplace app)
ZOOM_WEBHOOK_SECRET=

# PORT=3001
